#!/bin/bash
# vim: syntax=bash:

set -e

BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "${BASEDIR}/install-conf/utils.sh"

DOTBOT_DIR="modules/dotbot"

function dotbot_install() {
    CONFIG="install-conf/dotbot.conf.yaml"
    DOTBOT_BIN="bin/dotbot"

    log "Install with dotbot config"
    "${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" -c "${CONFIG}" "${@}"
    echo ""
}

function dotbot_init() {
    log "Initialize dotbot module"
    git -C "${DOTBOT_DIR}" submodule sync --quiet --recursive
    git submodule update --init --recursive "${DOTBOT_DIR}"
    echo ""
}

function dotbot_main() {
    dotbot_init
    dotbot_install "$@"
}

function os_packages_main() {
    if is_osx; then
        # shellcheck source=/dev/null
        . install-conf/homebrew-install.sh
        # Make sure brew is in PATH for later steps
        if [[ -f "/opt/homebrew/bin/brew" ]]; then
            eval "$(/opt/homebrew/bin/brew shellenv)"
        fi
    elif is_linux; then
        linux_install zsh
        linux_install vim
        linux_install neovim
    else
        error "Unknown OSTYPE: $OSTYPE"
    fi
}

function dev_tools_main() {
    if ! check_command mise; then
        log "Installing mise..."
        if is_osx; then
            brew install mise
        elif is_linux; then
            MISE_QUIET=1 curl -s https://mise.run | sh
            # Ensure it is in PATH for this script session
            export PATH="$HOME/.local/bin:$PATH"
        fi
    fi

    if check_command mise; then
        # Activate mise to ensure its shims are in PATH and can be used immediately
        eval "$(mise activate bash)"

        # Bootstrap bun and rust first so mise can use them for npm: and cargo: packages
        log "Bootstrapping bun and rust via mise..."
        mise install bun rust -y

        # At this point, Phase 1 has already symlinked ~/.config/mise/config*.toml
        # So mise will read the correct global config when running install
        log "Running 'mise install' to fetch the remaining CLI tools..."
        mise install -y
    else
        error "mise not found! Installation failed."
    fi
}

function vim_plugins_main() {
    log "Install VIM plugins"
    # Plugins update (Mason, Plug, etc)
    # shellcheck source=/dev/null
    . config/vim/update
}

function zsh_setup_main() {
    if [[ "$SHELL" != *zsh ]]; then
        log "Current shell is not zsh, switch default shell to zsh"
        chsh -s "$(which zsh)"
    fi
}

function main() {
    umask 022

    pushd "${BASEDIR}"

    print_stage "Phase 1: Create Symlinks (Dotbot)"
    dotbot_main "$@"

    print_stage "Phase 2: Install OS dependencies (OS Packages)"
    os_packages_main

    print_stage "Phase 3: Install development tools (Dev Tools)"
    dev_tools_main

    print_stage "Phase 4: Install Vim/Neovim plugins"
    vim_plugins_main

    print_stage "Phase 5: Set Zsh as default shell"
    zsh_setup_main

    print_stage "Installation Completed Successfully! 🎉"

    popd >/dev/null

    # Switch shell at the very last step to replace the old behavior that caused script restarting mid-way
    if [[ "$SHELL" != *zsh ]]; then
        log "Restarting shell to apply changes..."
        exec zsh -l
    fi
}

main "$@"
