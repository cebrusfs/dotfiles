#!/bin/bash
# vim: syntax=sh:

set -e

BASEDIR="$(dirname "${BASH_SOURCE[0]}")"
source "${BASEDIR}/install-conf/utils.sh"


DOTBOT_DIR="modules/dotbot"

function dotbot_install() {
    log "Install with dotbot config '$1'"
    "${DOTBOT_DIR}/bin/dotbot" -d "${BASEDIR}" -c "${@}"
    echo ""
}

function dotbot_init() {
    log "Initialize dotbot module"
    git submodule update --init --recursive "${DOTBOT_DIR}"
    echo ""
}

function dotbot_main() {
    if is_osx; then
        OS_CONFIG="dotbot-osx.conf.yaml"
    elif is_linux; then
        OS_CONFIG="dotbot-linux.conf.yaml"
    else
        error "Unkown OSTYPE: $OSTYPE"
    fi

    dotbot_init

    log "Install with dotbot config"
    dotbot_install "install-conf/dotbot-global.conf.yaml" "${@}"
    dotbot_install "install-conf/${OS_CONFIG}" "${@}"
    echo ""
}

function install_vim_deps_via_homebrew() {
    if ! check_command brew; then
        error "No brew installed."
    fi

    brew bundle -v --no-lock --file="homebrew/Brewfile.min"
}

function is_pkg_installed() {
    dpkg-query -W --showformat='${Status}\n' "$1" | \
        grep -q "install ok installed"
    # dpkg -l "$1" >/dev/null 2>&1
}

function apt_install() {
    log "Trying to install package '$1'"
    is_pkg_installed "$1" || sudo apt install -y "$1"
}

function install_vim_deps_via_apt() {
    # coc.nvim deps
    apt_install nodejs

    apt_install neovim

    # apt_install python3-dev
    # apt_install python3-dev
    # apt_install python3-pip
    # apt_install ruby-dev
    # apt_install npm
}

function install_vim_pkgs() {
    # Core
    log "Install packages for neovim core"
    # pip3 install --user neovim
    # gem install --user-install neovim
    # npm install -g neovim

    log "Install packages for neovim languages"

    # CoC: Ruby
    gem install --user-install solargraph rubocop
    # TODO: coc-pyright, python path
    # TODO: coc-go
    # TODO: node, npm, typescript, coc-tsserver
    # TODO: coc-css
    # TODO: rust coc-rust-analyzer
    # TODO: exection of each languages
}

function vim_main() {
    log "Install VIM dependancies"
    if is_osx; then
        install_vim_deps_via_homebrew
    elif is_linux; then
        install_vim_deps_via_apt
    else
        error "Unkown OSTYPE: $OSTYPE"
    fi

    install_vim_pkgs

    # install vim plugin
    . "config/vim/update"
}

function main() {
    pushd "${BASEDIR}"

    dotbot_main
    vim_main

    popd
}

main
