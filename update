#!/bin/bash
# vim: syntax=sh:
#
# ============================================================================
# ROLE & GOAL:
# This is the "Daily Upgrade & Pull" script.
# Its purpose is to quickly pull the latest changes from the dotfiles repository
# and upgrade existing dev tools to their latest versions. It intentionally skips
# the heavy installation and pruning steps (`mise prune`) to avoid unintentionally
# wiping out manually installed or experimental tools. Run this for regular maintenance.
# ============================================================================

set -e

BASEDIR="$(dirname "${BASH_SOURCE[0]}")"
source "${BASEDIR}/install-conf/utils.sh"

# Pull the latest commits from the dotfiles repository
function update_self() {
    log "Pull/update dotfiles"

    # git parameters might not be supported by older Git versions
    # autostash is Git 2.6.0 or later.
    # recurse-submodules is Git 2.14 or later.
    git pull --autostash --recurse-submodules 2>/dev/null || git pull --autostash 2>/dev/null || git pull
}

# Update external git submodules to their remote or pinned versions
function update_submodule() {
    #zprezto-update

    # Pull remote submodule
    # This will also update the nested submodules, we will need to restore them back
    git submodule update --remote

    # For each nested submodule, we need to enforce them to use pinned commit
    git submodule foreach --recursive git submodule update --init
}

# Hard reset submodules to the committed state (unused by default, but available for recovery)
function restore_submodule() {
    git submodule sync --recursive
    git submodule update --init --recursive
}

# Upgrade all development tools managed by `mise` (without pruning unlisted ones)
function update_dev_tools() {
    if check_command mise; then
        log "Upgrading dev tools via mise..."
        mise upgrade -y
    fi
}

function apply_codex_config() {
    if ! check_command python3; then
        error "python3 is required to sync Codex config"
    fi

    log "Sync Codex config"
    python3 config/agent/codex/sync-config.py --apply
}

function main() {
    pushd "${BASEDIR}"

    update_self
    update_submodule
    apply_codex_config

    # Remove fzf configs
    rm -f ~/.fzf.bash ~/.fzf.zsh
    rm -rf "${BASEDIR}/modules/fzf/"

    # update vim plugin
    . config/vim/update

    update_dev_tools

    # shellcheck disable=SC2119
    popd >/dev/null
}

main
