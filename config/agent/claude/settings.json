{
  "includeCoAuthoredBy": false,
  "permissions": {
    "deny": [
      "Bash(jj git *)",
      "Bash(jj op *)"
    ]
  },
  "model": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'command -v python3 >/dev/null 2>&1 || exit 0; exec python3 \"$HOME/.dotfiles/config/agent/hooks/commit-message-check.py\"'",
            "statusMessage": "Checking commit message"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.dotfiles/config/agent/hooks/commit-nudge.sh\""
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.dotfiles/config/agent/hooks/jj-workspace-create.sh\""
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.dotfiles/config/agent/hooks/jj-workspace-remove.sh\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {},
  "language": "台灣繁體中文",
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true
}
