{
    "coc.preferences.extensionUpdateCheck": "daily",

    // Enable semantic tokens highlight feature
    "semanticTokens.enable": true,

    // Enable coc-highlight for all filetype
    // "colors.enable": true,

    // git coloring
    "git.addGBlameToBufferVar": true,
    "git.addedSign.hlGroup": "GitGutterAdd",
    "git.changedSign.hlGroup": "GitGutterChange",
    "git.removedSign.hlGroup": "GitGutterDelete",
    "git.topRemovedSign.hlGroup": "GitGutterDelete",
    "git.changeRemovedSign.hlGroup": "GitGutterChangeDelete",

    // C / C++
    "clangd.fallbackFlags": ["-std=gnu++20", "-Wall", "-Wextra", "-Wshadow", "-Wno-deprecated"],

    // Ruby
    "solargraph.formatting": true,

    // Python (pyright)
    "python.venvPath": "venv", // Load ./venv if possible
    "python.formatting.autopep8Args": [
        // Disable line wraping
        "--ignore=E501",
        "--experimental"
    ]
}
