# vim: syntax=sshconfig

# Adding compression to help speed up remote Vim.
# https://stackoverflow.com/a/34206244/358069
Compression yes

# SSH Multiplexing
Host corp*
    ControlMaster auto
    ControlPath /tmp/ctrlmasters-%C
    ControlPersist 600

