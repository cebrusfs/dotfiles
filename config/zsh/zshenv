# vim: ts=2: sts=2: sw=2:

#
# Defines environment variables.
# This file is sourced by all instances of Zsh, and thus,
# it should be kept as small as possible and should only define environment variables.
#
# Authors:
#   Sorin Ionescu <sorin.ionescu@gmail.com>
#

# OSX
# tar: Do NOT pack UI configuration file (e.g. .DS_Store)
export COPYFILE_DISABLE=true
# Homebrew: cask: Change default app install directory
export HOMEBREW_CASK_OPTS="--appdir=~/Applications"

# GPG
export GPG_TTY=`tty`

# Machine-local/private environment lives outside tracked dotfiles.
_zshenv_local="${${(%):-%x}:A:h}/config.local.zsh"
if [[ -r "$_zshenv_local" ]]; then
  source "$_zshenv_local"
fi
unset _zshenv_local

# Ensure that a non-login, non-interactive shell has a defined environment.
if [[ ( "$SHLVL" -eq 1 && ! -o LOGIN ) && -s "${ZDOTDIR:-$HOME}/.zprofile" ]]; then
  source "${ZDOTDIR:-$HOME}/.zprofile"
fi
