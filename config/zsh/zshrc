# SSH
# Hook ssh to change tmux window name
function ssh() {
    local window_name
    window_name="$1"

    if [[ "$#" != 1 || "${window_name:0:1}" == "-"  ]]; then
        window_name="ssh"
    fi

    # set window name to hostname if we are in the tmux
    if [[ -n "$TMUX" ]]; then
        tmux rename-window "${window_name}"
    fi

    local err_count=0
    while true; do
        local start_time=$(date +%s)

        /usr/bin/env ssh "$@"

        # break if no error
        local return_code=$?
        [[ $return_code -ne 255 ]] && break

        local end_time=$(date +%s)

        local time_diff=$(( $end_time - $start_time ))
        if (( $time_diff < 10 )); then
            ((err_count += 1))
        else
            err_count=0
        fi
        [[ $err_count -gt 10 ]] && break

        echo "\r\e[1;33m[Disconnected. Retry ssh at $(date '+%F %T')...]\e[0m"
        sleep 1
    done

    # reset window name if we are in the tmux
    if [[ -n "$TMUX" ]]; then
        tmux set-window-option automatic-rename
    fi
    return $return_code
}

