# vim: syntax=zsh:

#
# Executes commands at the start of an interactive session.
#

# Source Prezto.
ZDOT_DIR=${ZDOT_DIR:-$HOME/.dotfiles/}
ZPREZTO_DIR=${ZPREZTO_DIR:-$ZDOT_DIR/modules/prezto}
INIT_PATH="$ZPREZTO_DIR/init.zsh"
if [[ -s "$INIT_PATH" ]]; then
    source "$INIT_PATH"
fi


# Warning for old configuration
if [[ -s "$HOME/.zprezto/init.zsh" ]]; then
    echo "[WARN] $HOME/.zprezto is exists, use the following command to delete it"
    echo "    rm -rf $HOME/.zprezto"
fi


#
# Customize to your needs...
#

function check_command () {
    command -v $1 >/dev/null
}

bindkey "^R" history-incremental-pattern-search-backward
bindkey -M vicmd '/' history-incremental-pattern-search-backward

# overwrite when using file redirect (>) to existed file
setopt clobber

# Disable ctrl-s for stop output by terminal.
stty -ixon

#
# ls colors
#
# Tool: https://geoff.greer.fm/lscolors/

# BSD (mac)
export LSCOLORS="Gxfxcxdxbxegedabagacad"
# Linux
export LS_COLORS="di=1;36:ln=35:so=32:pi=33:ex=31:bd=34;46:cd=34;43:su=30;41:sg=30;46:tw=30;42:ow=30;43"
# zsh (use Linux format)
zstyle ':completion:*:default' list-colors ${(s.:.)LS_COLORS}


#
# Alias
#

alias rm='rm -r'
alias cp='cp -rv'
alias objdump='objdump -M intel'
alias gistp='gist -p'

# Use 'colordiff' instead of 'diff'
check_command colordiff && alias diff='colordiff'

# Better rg wrapper for 'find'
function rgg () {
    rg --colors=path:none --files -g "*$1*"
}

# Use 'tmx2' instead of 'tmux' when available
check_command tmx2 && alias tmux='tmx2'

