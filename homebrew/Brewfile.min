# vim: syntax=brewfile:

#
# Minimal dependancy for dotfile
#

cask_args appdir: "~/Applications", require_sha: true


#
# Shell / System Util Core
#

# General binary manager for managing python, ruby, golang...etc
brew "mise"


#
# Shell and VIM
#

cask "iterm2"

# Font support ligatures. Suggested by VS Code
cask "font-fira-code-nerd-font"
# Fallback font. Suggested by p10k.
cask "font-meslo-lg-nerd-font"
