# vim: syntax=brewfile:

#
# Mac at home
# All stuff without CTF tools
#

# Load Brewfile.min
instance_eval File.new("#{ENV['HOME']}/.dotfiles/homebrew/Brewfile.work").read


#
# Remote Working & VCS (Personal Mac only)
#
brew "tmux"
brew "git"
brew "jj"                       # Next-gen VCS

#
# sudo required
#

#cask "bitwarden"            # Password manager (Used App Store)

cask "clip-studio-paint"    # painting

#
# Developing
#

# Agent
cask "claude"

# IDE tools
cask "visual-studio-code"
cask "antigravity"

# Container
cask "orbstack"             # faster Docker client/server on Mac

# GPG tools
#cask "gpg-suite-no-mail"
#brew "gnupg"

# VPN client
# Wireguard (Used App store)
# Tailscale (Used App store)

#
# Programming Language
#

# C / C++
brew "cmake"
brew "gcc"
brew "clang-format"

# Haskell
brew "ghc"
brew "cabal-install"

# Javascript
# node is managed by mise (config/mise/config.toml), not brew — see cleanup_legacy.sh

# Golang
brew "go"

# Markdown
brew "pandoc"

# Javascript / Typescript
brew "typescript"

# Media tools
brew "ffmpeg"
brew "yt-dlp"

# 7z CLI
brew "p7zip"

#
# Apps
#

cask "notion"

cask "vlc"                      # Video player

#cask "calibre"                 # ebook manager

cask "slack"
cask "discord"

#cask "anki"                    # Language learning
#cask "resilio-sync"            # P2P sync


#
# Missing verifying
#   Need manually install
#

cask "google-chrome"            # No need in work profile as it is installed by default
cask "google-drive"

